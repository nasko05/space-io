# Editor frontend build-time configuration (Vite). Copy to web/.env before
# `npm run build`. These are baked into the bundle at build time, so they are
# NOT secrets — only public URLs belong here.

# Full URL of the co-hosted cloud drive. When set, a "Cloud drive" link appears
# in the editor (rail + login screen); the shared SSO cookie keeps you signed in
# across the jump. Leave empty to hide the link (editor runs standalone).
VITE_DRIVE_URL=https://drive.example.com

# WebAuthn relying-party id for the passkey-derived unlock. In plug-in mode set
# this to the registrable PARENT domain shared by the drive and the editor (e.g.
# `example.com`, when the editor is at personal-area.example.com), so the single
# passkey registered on the drive works here too. Must match the drive's
# DRIVE_WEBAUTHN_RP_ID. Leave empty for a standalone editor (defaults to the
# editor's own hostname).
# VITE_WEBAUTHN_RP_ID=example.com
