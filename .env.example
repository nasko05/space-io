# SpaceIO server configuration — copy to `.env` and fill in:
#
#   cp .env.example .env
#   ./deploy.sh                       # auto-loads ./.env (docker or native)
#
# Or pass it explicitly / point elsewhere:
#
#   ./deploy.sh --env-file /etc/space-io.env
#   docker run --env-file .env -p 7777:7777 -v space-io-data:/data space-io
#
# Format rules (so one file works for both Docker and native):
#   - KEY=value, with NO quotes and NO spaces around '='.
#     Docker's --env-file keeps quotes literally, so `KEY="x"` stores `"x"`.
#   - Full-line `#` comments only; no inline `KEY=value # comment`.
#   - An empty value (KEY=) is treated as unset.
#
# Everything here is OPTIONAL. With no key set, the AI assistant simply stays
# hidden and nothing leaves the machine.

# ---- AI assistant ---------------------------------------------------------

# Turn the in-app assistant on by providing an OpenRouter API key.
SPACEIO_OPENROUTER_API_KEY=

# Chat model id. Any tool-calling model on OpenRouter works.
SPACEIO_AGENT_MODEL=qwen/qwen3.6-27b

# Point at any OpenAI-compatible endpoint (default: OpenRouter).
#SPACEIO_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Web search: leave this unset to use OpenRouter's built-in web plugin (no
# extra key). Set a Brave Search key to have the agent query Brave directly.
#SPACEIO_BRAVE_API_KEY=

# Set to 0 to disable web search entirely (default: 1 / on).
#SPACEIO_AGENT_WEB_SEARCH=1

# Max tool rounds the agent runs per message (default: 8).
#SPACEIO_AGENT_MAX_STEPS=8

# ---- Cloud-drive single sign-on (SSO) -------------------------------------

# When co-hosting the cloud drive (cloud-storage-system), the editor accepts the
# drive's login: it verifies the drive's HS256 session token from a cookie the
# drive shares across the parent domain. Set this to the SAME value as the
# drive's DRIVE_SECRET_KEY. Leave it unset to disable SSO and use the editor's
# own email + passphrase login only.
SPACEIO_SSO_JWT_SECRET=

# Name of the cookie the drive sets (must match the drive's DRIVE_SSO_COOKIE_NAME).
#SPACEIO_SSO_COOKIE_NAME=drive_sso

# Build-time (Vite) UI config, baked into the bundle. With `docker compose`,
# values set here are passed to the image build as build args (see Dockerfile /
# docker-compose.yml). For a manual `npm run build` set them in web/.env instead.
#   VITE_DRIVE_URL        full URL of the cloud drive ("Cloud drive" link + the
#                         passkey-only sign-in routing). Empty = standalone editor.
#   VITE_WEBAUTHN_RP_ID   the shared registrable PARENT domain, matching the
#                         drive's DRIVE_WEBAUTHN_RP_ID, so one passkey works on both.
#VITE_DRIVE_URL=https://drive.example.com
#VITE_WEBAUTHN_RP_ID=example.com

# ---- Server ---------------------------------------------------------------

# deploy.sh sets SPACEIO_INSECURE_COOKIES=1 by default (plain HTTP) and that
# deploy flag overrides this file, so prefer `--secure-cookies` over editing
# it here. Listen address / port / data dir are deploy.sh flags
# (--host / --port / --data), not server env vars.
