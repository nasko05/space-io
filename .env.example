# Hearth server configuration — copy to `.env` and fill in:
#
#   cp .env.example .env
#   ./deploy.sh                       # auto-loads ./.env (docker or native)
#
# Or pass it explicitly / point elsewhere:
#
#   ./deploy.sh --env-file /etc/hearth.env
#   docker run --env-file .env -p 7777:7777 -v hearth-data:/data hearth
#
# Format rules (so one file works for both Docker and native):
#   - KEY=value, with NO quotes and NO spaces around '='.
#     Docker's --env-file keeps quotes literally, so `KEY="x"` stores `"x"`.
#   - Full-line `#` comments only; no inline `KEY=value # comment`.
#   - An empty value (KEY=) is treated as unset.
#
# Everything here is OPTIONAL. With no key set, the AI assistant simply stays
# hidden and nothing leaves the machine.

# ---- AI assistant ---------------------------------------------------------

# Turn the in-app assistant on by providing an OpenRouter API key.
HEARTH_OPENROUTER_API_KEY=

# Chat model id. Any tool-calling model on OpenRouter works.
HEARTH_AGENT_MODEL=qwen/qwen3.6-27b

# Point at any OpenAI-compatible endpoint (default: OpenRouter).
#HEARTH_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Web search: leave this unset to use OpenRouter's built-in web plugin (no
# extra key). Set a Brave Search key to have the agent query Brave directly.
#HEARTH_BRAVE_API_KEY=

# Set to 0 to disable web search entirely (default: 1 / on).
#HEARTH_AGENT_WEB_SEARCH=1

# Max tool rounds the agent runs per message (default: 8).
#HEARTH_AGENT_MAX_STEPS=8

# ---- Server ---------------------------------------------------------------

# deploy.sh sets HEARTH_INSECURE_COOKIES=1 by default (plain HTTP) and that
# deploy flag overrides this file, so prefer `--secure-cookies` over editing
# it here. Listen address / port / data dir are deploy.sh flags
# (--host / --port / --data), not server env vars.
