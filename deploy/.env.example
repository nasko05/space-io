# Copy to deploy/.env and edit. The deploy script auto-loads
# deploy/.env (gitignored) so you don't have to remember these
# every session. Override with --env-file PATH or skip with
# --no-env-file.

# AWS auth — pick one
HEARTH_AWS_PROFILE=dev-creds
AWS_REGION=us-east-1

# Required for `up`. Must already exist in the target region — see
# "Get a key pair" in deploy/README.md for how to create or import.
HEARTH_KEYPAIR=hearth

# Optional
# HEARTH_STACK=hearth
# HEARTH_ALLOWED_CIDR=203.0.113.5/32
# HEARTH_INSTANCE_TYPE=t4g.nano
# HEARTH_DATA_GIB=8
# HEARTH_REPO_URL=https://github.com/nasko05/space-io.git
# HEARTH_REPO_REF=main
